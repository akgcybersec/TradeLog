# Copy to .env — do not commit .env
# Generate: openssl rand -base64 32

SESSION_SECRET=replace-with-a-random-string-at-least-32-characters-long
DATABASE_URL=file:./prisma/dev.db

# Set false when using http:// (e.g. LAN IP) without HTTPS — otherwise login cookies are ignored
COOKIE_SECURE=false

# Docker Compose only
APP_PORT=3000
